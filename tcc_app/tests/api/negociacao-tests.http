### ===== ENDPOINTS DA CALCULADORA DE NEGOCIAÇÃO =====

### 11 - Calcular Valores da Negociação
POST {{baseUrl}}/api/negotiations/calculate-values
Content-Type: {{contentType}}

{
  "valorDivida": 1000.00,
  "percentualDesconto": 15.0
}

### 12 - Gerar Parcelas Iguais
POST {{baseUrl}}/api/negotiations/generate-installments
Content-Type: {{contentType}}

{
  "valorTotal": 850.00,
  "numeroParcelas": 3,
  "dataInicio": "2024-01-15",
  "intervaloDias": 30,
  "percentualMulta": 2.0,
  "tipo": "iguais"
}

### 13 - Gerar Parcelas Decrescentes
POST {{baseUrl}}/api/negotiations/generate-installments
Content-Type: {{contentType}}

{
  "valorTotal": 1200.00,
  "numeroParcelas": 4,
  "dataInicio": "2024-01-15",
  "intervaloDias": 30,
  "percentualMulta": 2.0,
  "tipo": "decrescentes",
  "percentualPrimeiraParcela": 40
}

### 14 - Calcular Valor com Atraso
POST {{baseUrl}}/api/negotiations/calculate-overdue
Content-Type: {{contentType}}

{
  "valorOriginal": 500.00,
  "percentualMulta": 2.0,
  "percentualJurosMensal": 1.0,
  "mesesAtraso": 3
}

### 15 - Validar Cálculos de Negociação
POST {{baseUrl}}/api/negotiations/validate-calculations
Content-Type: {{contentType}}

{
  "valorDivida": 1000.00,
  "valorDesconto": 100.00,
  "taxaDesconto": 10.0,
  "valorTotal": 900.00,
  "valorFinal": 900.00,
  "effectiveDate": "2024-01-15",
  "startDate": "2024-01-15",
  "endDate": "2024-12-31",
  "eParcelado": true,
  "isParcelaIgual": true,
  "totalParcelas": 3,
  "processes": [
    { "id": 1 }
  ],
  "parcelas": [
    {
      "numeroParcela": 1,
      "valorParcela": 300.00,
      "valorPercentual": 33.33,
      "dataVencimento": "2024-04-15",
      "percentualMulta": 2.0
    },
    {
      "numeroParcela": 2,
      "valorParcela": 300.00,
      "valorPercentual": 33.33,
      "dataVencimento": "2024-07-15",
      "percentualMulta": 2.0
    },
    {
      "numeroParcela": 3,
      "valorParcela": 300.00,
      "valorPercentual": 33.34,
      "dataVencimento": "2024-10-15",
      "percentualMulta": 2.0
    }
  ]
}
